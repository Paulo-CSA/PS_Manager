{
  "entities": {
    "machine": {
      "title": "Machine",
      "description": "Details of a managed computer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ip": { "type": "string", "format": "hostname" },
        "status": { "type": "string", "enum": ["online", "offline", "unknown"] },
        "lastPing": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ip", "ownerId"]
    },
    "credential": {
      "title": "Credential",
      "description": "Remote access credentials",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "password", "ownerId"]
    }
  },
  "firestore": {
    "machines": {
      "schema": "machine",
      "description": "Collection of machines to manage"
    },
    "credentials": {
      "schema": "credential",
      "description": "Collection of user credentials (usually 1 per user)"
    }
  }
}
